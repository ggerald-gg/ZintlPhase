    "minecraft:wooden_shovel",
    "minecraft:wooden_sword",
    "overgeared:copper_nugget",
    "overgeared:copper_plate",
    "overgeared:diamond_upgrade_smithing_template",
    "overgeared:iron_plate",
    "overgeared:steel_block",
    "overgeared:steel_ingot",
    "overgeared:steel_nugget",
    "overgeared:steel_plate",
    "!overgeared:.*_axe",
    "!overgeared:.*_boots",
    "!overgeared:.*_chestplate",
    "!overgeared:.*_head",
    "!overgeared:.*_helmet",
    "!overgeared:.*_hoe",
    "!overgeared:.*_leggings",
    "!overgeared:.*_pickaxe",
    "!overgeared:.*_shovel",
    "!overgeared:.*_sword_blade",
